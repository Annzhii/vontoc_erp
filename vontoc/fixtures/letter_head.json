  "footer": "<div style=\"position: fixed; bottom: 10px; width: 100%; font-size: 9pt; box-sizing: border-box;\">\n\n  <!-- 银行信息 -->\n  <div style=\"font-weight: bold;\">Bank Information</div>\n  <table style=\"border-collapse: collapse; margin-bottom: 10px; font-size: 9pt; border-top: 1px solid #eee; line-height:12px;\">\n    <tbody>\n      <tr>\n        <td style=\"padding: 1px;\">Bank Name:</td>\n        <td style=\"padding: 1px;\">HSBC Hong Kong</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 1px;\">SWIFT:</td>\n        <td style=\"padding: 1px;\">HSBCHKHHHKH</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 1px;\">Beneficiary Name:</td>\n        <td style=\"padding: 1px;\">FOW GROUP LIMITED</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 1px;\">Bank Account No:</td>\n        <td style=\"padding: 1px;\">747238350838</td>\n      </tr>\n    </tbody>\n  </table>\n</div>\n\n<!-- 占位-->\n<div style=\"height: 120px;\"></div>\n",
