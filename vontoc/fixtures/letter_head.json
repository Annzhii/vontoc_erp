  "content": "<table style=\"width: 100%; font-size: 9pt;\">\n  <tbody><tr>\n    <!-- 左边：Logo + 地址 -->\n    <td style=\"width: 50%; vertical-align: top;\">\n      <div style=\"width: 90px; display: block;\">\n          {% set company_logo = frappe.db.get_value(\"Company\", doc.company, \"company_logo\") %}\n          {% if company_logo %}\n              <img style=\"max-width: 90px; max-height: 90px; display: inline-block;\" src=\"{{ frappe.utils.get_url(company_logo) }}\" alt=\"Company Logo\">\n          {% endif %}\n      </div>\n      <div>{{ doc.company_address_display or '' }}</div>\n    </td>\n\n    <!-- 右边：表单名称（自动识别） + 日期字段 -->\n    <td style=\"text-align: right; vertical-align: top;\">\n      <div class=\"doc-type-title\">PROFORMA INVOICE</div>\n      <div class=\"doc-name\"> {{_(doc.name)}}</div>\n      <br>\n      <div>\n        <b>Date:</b> {{ doc.date or doc.transaction_date or '' }}<br>\n        <b>Valid Till:</b> {{ doc.valid_till or '' }} <br>\n        <b>Prepared By:</b> {{ frappe.db.get_value(\"User\", frappe.session.user, \"full_name\") }}\n      </div>\n    </td>\n  </tr>\n</tbody></table>",
